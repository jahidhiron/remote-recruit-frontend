# ============================================================
# RemoteRecruit — Environment Variables
# ============================================================
# Vite loads mode-specific files automatically:
#   .env.development  →  pnpm dev  /  pnpm build:dev
#   .env.staging      →  pnpm build:staging
#   .env.production   →  pnpm build:prod
#
# Copy this file to the relevant .env.<mode> file and fill
# in the actual values. Never commit .env or .env.* files.
# ============================================================

# ── App ──────────────────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_PORT=4000

# ── API ──────────────────────────────────────────────────────
# Base URL for all API requests (no trailing slash)
# development:  http://localhost:3000/api/v1
# staging:      https://api.staging.remoterecruit.com/api/v1
# production:   https://api.remoterecruit.com/api/v1
VITE_API_BASE_URL=https://api.remoterecruit.com/api/v1

# ── Redux Persist ────────────────────────────────────────────
VITE_REDUX_PERSIST_KEY=remote-recruit
